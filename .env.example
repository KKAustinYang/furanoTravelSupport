# Copy this file to .env.local and fill in real values. .env.local is gitignored.
# In Vercel, set these in Project → Settings → Environment Variables.

# Modellix key — SERVER-SIDE ONLY (no VITE_ prefix), so it is never sent to the browser.
# Used by the serverless proxy (api/[...path].js) and the Vite dev proxy.
MODELLIX_KEY=mdlx-xxxxxxxxxxxxxxxxxxxxxxxx

# EngageLab WebPush appkey (public, optional — leave empty to disable web push).
VITE_ENGAGELAB_APPKEY=
