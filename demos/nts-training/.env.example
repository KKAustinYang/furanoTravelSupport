# 評価用 GPTBots Agent の API キー（音声→JSON評価Agent）
# GPTBots 後台 → Agent → 集成 → API → APIKey で発行して貼り付け
# ※ 実際のキーは .env（gitignore 済み）に書く。このファイルには書かない。
GPTBOTS_APIKEY_OUTBOUND=app-xxxxxxxxxxxxxxxxxxxxxxxx   # 定期案内（アウトバウンド）評価Agent
GPTBOTS_APIKEY_INBOUND=app-xxxxxxxxxxxxxxxxxxxxxxxx    # 解約対応（インバウンド）評価Agent

# データセンター: sg（Singapore）/ jp（Japan）/ th（Thailand）
GPTBOTS_ENDPOINT=jp

# 評価プロキシ(server.js)のポート（変更不要）
PORT=8787
